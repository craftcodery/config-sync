# -----------------------------------------------------------------------------
# Organization Internal Account
# -----------------------------------------------------------------------------

# Default profile uses 1Password for credentials
[default]
credential_process = __HELPER_PATH__ "AWS - Acme" "Employee"
mfa_process = __HELPER_PATH__ "AWS - Acme" "Employee" --otp
mfa_serial = __MFA_SERIAL:AWS - Acme:Employee__
region = us-east-1

# -----------------------------------------------------------------------------
# SSO Configuration (optional)
# -----------------------------------------------------------------------------
# Once AWS IAM Identity Center is configured, uncomment and update:
#
# [profile acme-sso]
# sso_start_url = https://your-org.awsapps.com/start
# sso_region = us-east-1
# sso_account_id = YOUR_ACCOUNT_ID
# sso_role_name = AdministratorAccess
# region = us-east-1

# =============================================================================
# Client/Project Accounts
# Credentials stored in 1Password
#
# IMPORTANT: Set OP_ACCOUNT environment variable in your shell profile:
#   export OP_ACCOUNT="your-team.1password.com"
#
# Add to ~/.zshrc or ~/.bashrc to make persistent
# =============================================================================

