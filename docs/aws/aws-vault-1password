#!/bin/bash
# aws-vault-1password: Fetches AWS credentials or TOTP from 1Password
#
# Usage:
#   aws-vault-1password "Item Name" "Vault Name"              # Get credentials
#   aws-vault-1password "Item Name" "Vault Name" --otp        # Get TOTP code
#   aws-vault-1password "Item Name" "Vault Name" --validate   # Validate entry format
#
# Environment Variables:
#   OP_ACCOUNT - 1Password account to use (e.g., "craftcodery.1password.com")
#                If not set, uses default account or prompts if multiple exist
#
# Expected 1Password item structure (see docs/1password-aws-standard.md):
#   - Access Key ID: AWS access key (starts with AKIA...)
#   - Secret Access Key: AWS secret key
#   - One-time password: TOTP secret (for MFA)
#
# This script is called by AWS CLI via credential_process and mfa_process

set -euo pipefail

# Validate arguments
if [ $# -lt 2 ]; then
    echo "Usage: aws-vault-1password <item-name> <vault-name> [--otp|--validate]" >&2
    echo "" >&2
    echo "Modes:" >&2
    echo "  (default)   Return AWS credentials in JSON format" >&2
    echo "  --otp       Return TOTP code for MFA" >&2
    echo "  --validate  Check if entry is properly configured" >&2
    echo "" >&2
    echo "Environment:" >&2
    echo "  OP_ACCOUNT  1Password account (e.g., craftcodery.1password.com)" >&2
    exit 1
fi

ITEM="$1"
VAULT="$2"
MODE="${3:-}"

# Check if 1Password CLI is available
if ! command -v op &> /dev/null; then
    echo "Error: 1Password CLI (op) not found." >&2
    echo "Install with: brew install --cask 1password-cli" >&2
    exit 1
fi

# Check if jq is available
if ! command -v jq &> /dev/null; then
    echo "Error: jq not found." >&2
    echo "Install with: brew install jq" >&2
    exit 1
fi

# Build account flag (default to craftcodery.1password.com)
OP_ACCOUNT="${OP_ACCOUNT:-craftcodery.1password.com}"
ACCOUNT_FLAG="--account $OP_ACCOUNT"

# Check if signed in to 1Password
# shellcheck disable=SC2086
if ! op account list $ACCOUNT_FLAG &> /dev/null; then
    echo "Error: Not signed in to 1Password." >&2
    echo "Open 1Password app to authenticate, or check OP_ACCOUNT setting." >&2
    exit 1
fi

# Function to get item JSON
get_item_json() {
    # shellcheck disable=SC2086
    op item get "$ITEM" --vault "$VAULT" $ACCOUNT_FLAG --format json 2>/dev/null
}

# Function to extract field value by trying multiple labels
extract_field() {
    local json="$1"
    shift
    local labels=("$@")

    for label in "${labels[@]}"; do
        local value
        value=$(echo "$json" | jq -r --arg label "$label" '
            .fields[] | select(.label == $label or .id == $label) | .value' | head -1)
        if [ -n "$value" ] && [ "$value" != "null" ]; then
            echo "$value"
            return 0
        fi
    done
    return 1
}

if [ "$MODE" == "--otp" ]; then
    # ==========================================================================
    # OTP Mode: Return TOTP code for MFA
    # ==========================================================================
    # shellcheck disable=SC2086
    OTP=$(op item get "$ITEM" --vault "$VAULT" $ACCOUNT_FLAG --otp 2>/dev/null) || {
        echo "Error: Could not retrieve TOTP from '$ITEM' in vault '$VAULT'" >&2
        echo "" >&2
        echo "Ensure the item has a one-time password (TOTP) field configured." >&2
        echo "In 1Password: Edit item → Add More → One-Time Password" >&2
        exit 1
    }

    if [ -z "$OTP" ]; then
        echo "Error: TOTP field is empty for '$ITEM'" >&2
        exit 1
    fi

    # mfa_process expects just the code on stdout
    echo "$OTP"

elif [ "$MODE" == "--validate" ]; then
    # ==========================================================================
    # Validate Mode: Check if entry is properly configured
    # ==========================================================================
    echo "Validating: $ITEM (vault: $VAULT)"
    echo ""

    ITEM_JSON=$(get_item_json) || {
        echo "✗ Could not retrieve item" >&2
        exit 1
    }
    echo "✓ Item found"

    # Check Access Key ID
    ACCESS_KEY=$(extract_field "$ITEM_JSON" "Access Key ID" "access_key_id" "AccessKeyId" "AWS_ACCESS_KEY_ID") || true
    if [ -z "$ACCESS_KEY" ]; then
        echo "✗ Access Key ID: NOT FOUND"
        echo "  Add a field labeled 'Access Key ID' with the AWS access key"
    elif [[ "$ACCESS_KEY" =~ ^AKIA ]]; then
        echo "✓ Access Key ID: ${ACCESS_KEY:0:8}... (valid IAM user key)"
    elif [[ "$ACCESS_KEY" =~ ^ASIA ]]; then
        echo "✓ Access Key ID: ${ACCESS_KEY:0:8}... (valid temporary key)"
    elif [[ "$ACCESS_KEY" =~ ^AIDA ]]; then
        echo "⚠ Access Key ID: ${ACCESS_KEY:0:8}... (this is an IAM User ID, not an access key)"
    else
        echo "⚠ Access Key ID: ${ACCESS_KEY:0:20}... (doesn't look like an AWS access key)"
        echo "  AWS access keys start with AKIA (user) or ASIA (temporary)"
    fi

    # Check Secret Access Key
    SECRET_KEY=$(extract_field "$ITEM_JSON" "Secret Access Key" "secret_access_key" "SecretAccessKey" "AWS_SECRET_ACCESS_KEY") || true
    if [ -z "$SECRET_KEY" ]; then
        echo "✗ Secret Access Key: NOT FOUND"
        echo "  Add a field labeled 'Secret Access Key' with the AWS secret key"
    elif [ ${#SECRET_KEY} -eq 40 ]; then
        echo "✓ Secret Access Key: ******** (valid length: 40 chars)"
    else
        echo "⚠ Secret Access Key: ******** (length: ${#SECRET_KEY} chars, expected: 40)"
    fi

    # Check TOTP
    # shellcheck disable=SC2086
    if op item get "$ITEM" --vault "$VAULT" $ACCOUNT_FLAG --otp &>/dev/null; then
        echo "✓ TOTP: Configured"
    else
        echo "○ TOTP: Not configured (optional, needed for MFA)"
    fi

    # Check additional metadata fields
    ACCOUNT_ID=$(extract_field "$ITEM_JSON" "AWS Account ID" "account_id" "AccountId") || true
    if [ -n "$ACCOUNT_ID" ]; then
        echo "✓ AWS Account ID: $ACCOUNT_ID"
    else
        echo "○ AWS Account ID: Not set (optional)"
    fi

    MFA_ARN=$(extract_field "$ITEM_JSON" "MFA Serial ARN" "mfa_serial" "MfaSerial") || true
    if [ -n "$MFA_ARN" ]; then
        echo "✓ MFA Serial ARN: $MFA_ARN"
    else
        echo "○ MFA Serial ARN: Not set (optional, needed for MFA)"
    fi

    echo ""
    if [ -n "$ACCESS_KEY" ] && [[ "$ACCESS_KEY" =~ ^A[KS]IA ]] && [ -n "$SECRET_KEY" ]; then
        echo "Result: ✓ Entry is properly configured for AWS CLI"
    else
        echo "Result: ✗ Entry needs updates (see above)"
        exit 1
    fi

else
    # ==========================================================================
    # Credential Mode: Return AWS credentials in JSON format
    # ==========================================================================

    ITEM_JSON=$(get_item_json) || {
        echo "Error: Could not retrieve '$ITEM' from vault '$VAULT'" >&2
        if [ -n "${OP_ACCOUNT:-}" ]; then
            echo "Account: $OP_ACCOUNT" >&2
        fi
        echo "" >&2
        echo "Check that:" >&2
        echo "  1. Item name is spelled correctly" >&2
        echo "  2. Vault name is spelled correctly" >&2
        echo "  3. You have access to this vault" >&2
        exit 1
    }

    if [ -z "$ITEM_JSON" ]; then
        echo "Error: Empty response from 1Password for '$ITEM'" >&2
        exit 1
    fi

    # Extract Access Key ID (do NOT use "username" - that's for console login)
    ACCESS_KEY=$(extract_field "$ITEM_JSON" \
        "Access Key ID" "access_key_id" "AccessKeyId" "AWS_ACCESS_KEY_ID") || true

    # Extract Secret Access Key (do NOT use "password" - that's for console login)
    SECRET_KEY=$(extract_field "$ITEM_JSON" \
        "Secret Access Key" "secret_access_key" "SecretAccessKey" "AWS_SECRET_ACCESS_KEY") || true

    # Validate Access Key ID
    if [ -z "$ACCESS_KEY" ]; then
        echo "Error: Could not find Access Key ID in '$ITEM'" >&2
        echo "" >&2
        echo "Expected field label: 'Access Key ID'" >&2
        echo "" >&2
        echo "Note: 'username' fields are reserved for console login credentials." >&2
        echo "Add a separate 'Access Key ID' field with your AWS access key (starts with AKIA)." >&2
        echo "" >&2
        echo "Run with --validate to diagnose: " >&2
        echo "  aws-vault-1password \"$ITEM\" \"$VAULT\" --validate" >&2
        exit 1
    fi

    # Warn if Access Key ID doesn't look right
    if [[ ! "$ACCESS_KEY" =~ ^A[KS]IA ]]; then
        echo "Warning: Access Key ID doesn't look like an AWS key: ${ACCESS_KEY:0:20}..." >&2
        echo "AWS access keys start with AKIA (user) or ASIA (temporary)" >&2
        echo "" >&2
    fi

    # Validate Secret Access Key
    if [ -z "$SECRET_KEY" ]; then
        echo "Error: Could not find Secret Access Key in '$ITEM'" >&2
        echo "" >&2
        echo "Expected field label: 'Secret Access Key'" >&2
        echo "" >&2
        echo "Note: 'password' fields are reserved for console login credentials." >&2
        echo "Add a separate 'Secret Access Key' field with your AWS secret key (40 chars)." >&2
        echo "" >&2
        echo "Run with --validate to diagnose: " >&2
        echo "  aws-vault-1password \"$ITEM\" \"$VAULT\" --validate" >&2
        exit 1
    fi

    # Output in AWS credential_process format
    # https://docs.aws.amazon.com/cli/latest/userguide/cli-configure-sourcing-external.html
    jq -n \
        --arg access_key "$ACCESS_KEY" \
        --arg secret_key "$SECRET_KEY" \
        '{
            Version: 1,
            AccessKeyId: $access_key,
            SecretAccessKey: $secret_key
        }'
fi
