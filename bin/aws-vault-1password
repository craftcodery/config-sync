#!/bin/bash
# aws-vault-1password: Fetches AWS credentials or TOTP from 1Password
#
# Usage:
#   aws-vault-1password "Item Name" "Vault Name"          # Get credentials
#   aws-vault-1password "Item Name" "Vault Name" --otp    # Get TOTP code
#
# Environment Variables:
#   OP_ACCOUNT - 1Password account to use (e.g., "craftcodery.1password.com")
#                If not set, uses default account or prompts if multiple exist
#
# Expected 1Password item structure:
#   - username: Access Key ID (or field labeled "Access Key ID")
#   - password: Secret Access Key (or field labeled "Secret Access Key")
#   - one-time password: TOTP secret (for MFA)
#
# This script is called by AWS CLI via credential_process and mfa_process

set -euo pipefail

# Validate arguments
if [ $# -lt 2 ]; then
    echo "Usage: aws-vault-1password <item-name> <vault-name> [--otp]" >&2
    echo "Set OP_ACCOUNT env var to specify 1Password account" >&2
    exit 1
fi

ITEM="$1"
VAULT="$2"
MODE="${3:-}"

# Check if 1Password CLI is available
if ! command -v op &> /dev/null; then
    echo "Error: 1Password CLI (op) not found. Please install it." >&2
    exit 1
fi

# Build account flag if OP_ACCOUNT is set
ACCOUNT_FLAG=""
if [ -n "${OP_ACCOUNT:-}" ]; then
    ACCOUNT_FLAG="--account $OP_ACCOUNT"
fi

# Check if signed in to 1Password
# shellcheck disable=SC2086
if ! op account list $ACCOUNT_FLAG &> /dev/null; then
    echo "Error: Not signed in to 1Password. Open 1Password app to authenticate." >&2
    exit 1
fi

if [ "$MODE" == "--otp" ]; then
    # ==========================================================================
    # OTP Mode: Return TOTP code for MFA
    # ==========================================================================
    # shellcheck disable=SC2086
    OTP=$(op item get "$ITEM" --vault "$VAULT" $ACCOUNT_FLAG --otp 2>/dev/null) || {
        echo "Error: Could not retrieve TOTP from 1Password item '$ITEM'" >&2
        exit 1
    }

    if [ -z "$OTP" ]; then
        echo "Error: TOTP is empty for item '$ITEM'" >&2
        exit 1
    fi

    # mfa_process expects just the code on stdout
    echo "$OTP"
else
    # ==========================================================================
    # Credential Mode: Return AWS credentials in JSON format
    # ==========================================================================

    # Get the item as JSON
    # shellcheck disable=SC2086
    ITEM_JSON=$(op item get "$ITEM" --vault "$VAULT" $ACCOUNT_FLAG --format json 2>/dev/null) || {
        echo "Error: Could not retrieve item '$ITEM' from vault '$VAULT'" >&2
        if [ -n "${OP_ACCOUNT:-}" ]; then
            echo "Account: $OP_ACCOUNT" >&2
        fi
        exit 1
    }

    if [ -z "$ITEM_JSON" ]; then
        echo "Error: Empty response from 1Password for item '$ITEM'" >&2
        exit 1
    fi

    # Extract Access Key ID (try multiple field labels)
    ACCESS_KEY=$(echo "$ITEM_JSON" | jq -r '
        .fields[] |
        select(
            .label == "username" or
            .label == "Username" or
            .label == "Access Key ID" or
            .label == "access_key_id" or
            .label == "AccessKeyId" or
            .label == "AWS_ACCESS_KEY_ID" or
            .id == "username"
        ) |
        .value' | head -1)

    # Extract Secret Access Key (try multiple field labels)
    SECRET_KEY=$(echo "$ITEM_JSON" | jq -r '
        .fields[] |
        select(
            .label == "password" or
            .label == "Password" or
            .label == "Secret Access Key" or
            .label == "secret_access_key" or
            .label == "SecretAccessKey" or
            .label == "AWS_SECRET_ACCESS_KEY" or
            .id == "password"
        ) |
        .value' | head -1)

    # Validate we got both values
    if [ -z "$ACCESS_KEY" ] || [ "$ACCESS_KEY" == "null" ]; then
        echo "Error: Could not find Access Key ID in 1Password item '$ITEM'" >&2
        echo "Expected field labels: username, Access Key ID, access_key_id" >&2
        exit 1
    fi

    if [ -z "$SECRET_KEY" ] || [ "$SECRET_KEY" == "null" ]; then
        echo "Error: Could not find Secret Access Key in 1Password item '$ITEM'" >&2
        echo "Expected field labels: password, Secret Access Key, secret_access_key" >&2
        exit 1
    fi

    # Output in AWS credential_process format
    # https://docs.aws.amazon.com/cli/latest/userguide/cli-configure-sourcing-external.html
    jq -n \
        --arg access_key "$ACCESS_KEY" \
        --arg secret_key "$SECRET_KEY" \
        '{
            Version: 1,
            AccessKeyId: $access_key,
            SecretAccessKey: $secret_key
        }'
fi
